# Copy to .dev.vars (gitignored) and fill in. Used by `wrangler dev`.
# Generate a secret: openssl rand -hex 32
AUTH_SECRET=replace-with-32-byte-hex
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret
# Local dev origin so Auth.js builds correct callback URLs.
AUTH_URL=http://localhost:8787
